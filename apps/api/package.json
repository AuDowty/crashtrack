{
  "name": "@crashtrack/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply crashtrack --local",
